<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noai, noimageai">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="stylesheet" href="{{ '/global.css' | cssBust }}">
{% if pageCss %}<link rel="stylesheet" href="{{ ('/' + pageCss) | cssBust }}">{% endif %}
<title>閱大安{% if title %}・{{ title }}{% endif %}</title>
{% if extraStyles %}<style>{{ extraStyles | safe }}</style>{% endif %}
{% if extraHead %}{{ extraHead | safe }}{% endif %}
{% if trilingual %}<script src="{{ '/lang.js' | cssBust }}" defer></script>{% endif %}
</head>
<body>
{%- set alertBanner = collections.notice | activeBanner -%}
{%- if alertBanner %}
<aside class="alert-banner" role="alert">
  <a href="{{ alertBanner.url }}" class="alert-banner-link">
    <span class="alert-banner-icon" aria-hidden="true">⚠</span>
    <span class="alert-banner-text">{{ alertBanner.data.bannerMessage or alertBanner.data.titleZh or alertBanner.data.title }}</span>
    <span class="alert-banner-cta">詳細說明 →</span>
  </a>
</aside>
{%- if not alertBanner.data.bannerUntil %}<!-- ⚠ alert "{{ alertBanner.data.title }}" has no bannerUntil and will display until manually removed -->{% endif %}
{% endif -%}
{#- ── 麵包屑（除首頁 / admin / 404 外自動產生）─────────────────────
    URL prefix → 區段標籤。命中其中之一才渲染；首頁、admin、404 等
    不出現在表內的頁，不產生 breadcrumb。第三段（具體頁）用 titleZh
    優先、否則 title。   ───────────────────────────────────────── #}
{%- set bcUrl = '' -%}
{%- set bcLabel = '' -%}
{#- 防呆：permalink:false 的頁（如 utility/electricity-trend.html 保留檔）page.url 是 false 不是字串；
    用 page.url | string 強制轉成空字串避免 'in' 操作炸鍋 -#}
{%- set pageUrl = page.url | string -%}
{%- if '/notice/' in pageUrl %}{% set bcUrl = '/notice/' %}{% set bcLabel = '社區公告' %}
{%- elif '/finance/' in pageUrl %}{% set bcUrl = '/finance/' %}{% set bcLabel = '財務月報' %}
{%- elif '/minutes/' in pageUrl %}{% set bcUrl = '/minutes/' %}{% set bcLabel = '會議紀錄' %}
{%- elif '/regulations/' in pageUrl %}{% set bcUrl = '/regulations/' %}{% set bcLabel = '規約辦法' %}
{%- elif '/welcome/' in pageUrl %}{% set bcUrl = '/welcome/' %}{% set bcLabel = '新住戶須知' %}
{%- elif '/utility/' in pageUrl %}{% set bcUrl = '/utility/' %}{% set bcLabel = '公共事業' %}
{%- elif '/directory/' in pageUrl %}{% set bcUrl = '/directory/' %}{% set bcLabel = '廠商聯絡簿' %}
{%- elif '/facility/' in pageUrl %}{% set bcUrl = '/facility/' %}{% set bcLabel = '公設使用登記' %}
{%- elif '/evacuation/' in pageUrl %}{% set bcUrl = '/evacuation/' %}{% set bcLabel = '緊急避難圖' %}
{%- elif '/net-zero/' in pageUrl %}{% set bcUrl = '/net-zero/' %}{% set bcLabel = '淨零新生活' %}
{%- elif '/transport/' in pageUrl %}{% set bcUrl = '/transport/' %}{% set bcLabel = '綠色運輸' %}
{%- elif '/green-labels/' in pageUrl %}{% set bcUrl = '/net-zero/' %}{% set bcLabel = '淨零新生活' %}
{%- elif pageUrl == '/search.html' %}{% set bcUrl = '/search.html' %}{% set bcLabel = '全站搜尋' %}
{%- endif -%}
{#- 全站頂部導覽帶：左側 breadcrumb（無區段時為空）+ 右側搜尋 icon。
    預設一律渲染；「公開頁」（frontmatter hideSiteNav: true，如 /intro/）不渲染——
    外部訪客沒有登入權限，麵包屑與站內搜尋只會把人帶去登入牆。 -#}
{%- if not hideSiteNav %}
<nav class="breadcrumb" aria-label="頂部導覽">
  <div class="breadcrumb-inner">
    <div class="breadcrumb-path">
      {%- if bcLabel %}
      <a href="/">閱大安</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      {%- if pageUrl == bcUrl %}
      <span class="breadcrumb-current">{{ bcLabel }}</span>
      {%- else %}
      <a href="{{ bcUrl }}">{{ bcLabel }}</a>
      {%- endif %}
      {%- endif %}
    </div>
    <button type="button" class="site-search-icon" aria-label="搜尋" aria-expanded="false" aria-controls="site-search-panel" onclick="toggleSiteSearch(this)">
      <svg class="icon-search" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.5" y2="16.5"></line>
      </svg>
      <svg class="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="6" y1="18" x2="18" y2="6"></line>
      </svg>
    </button>
  </div>
</nav>

{#- 點 icon 後從上方滑出的搜尋區塊；JS Esc / 再點 icon 收回；送出走 /search.html?q=... -#}
<div id="site-search-panel" class="site-search-panel" hidden>
  <form action="/search.html" method="get" role="search" class="site-search-panel-form">
    <input id="site-search-panel-input" name="q" type="search" class="site-search-panel-input" autocomplete="off" placeholder="搜尋公告、會議、規約、財報…" aria-label="搜尋關鍵字">
    <button type="submit" class="site-search-panel-btn" aria-label="送出搜尋">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.5" y2="16.5"></line>
      </svg>
    </button>
  </form>
</div>
<script>
function toggleSiteSearch(btn) {
  var panel = document.getElementById('site-search-panel');
  var open = btn.getAttribute('aria-expanded') === 'true';
  if (open) { closeSiteSearch(); return; }
  panel.hidden = false;
  btn.setAttribute('aria-expanded', 'true');
  requestAnimationFrame(function() {
    document.getElementById('site-search-panel-input').focus();
  });
}
function closeSiteSearch() {
  var panel = document.getElementById('site-search-panel');
  var btn = document.querySelector('.site-search-icon');
  panel.hidden = true;
  if (btn) { btn.setAttribute('aria-expanded', 'false'); btn.focus(); }
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var panel = document.getElementById('site-search-panel');
    if (panel && !panel.hidden) closeSiteSearch();
  }
});
</script>
{%- endif %}

{{ content | safe }}
{% if extraScripts %}<script>{{ extraScripts | safe }}</script>{% endif %}
</body>
</html>
