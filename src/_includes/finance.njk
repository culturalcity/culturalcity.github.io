---
layout: base.njk
pageCss: finance.css
extraHead: |
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/chartjs-plugin-datalabels/2.2.0/chartjs-plugin-datalabels.min.js"></script>
extraScripts: |
  // 把 .month-nav 搬到 .header 之後（nav 在模板渲染於 content 前，需移到 header 下方）
  (function relocateNav(){
    var nav = document.querySelector('.month-nav');
    var header = document.querySelector('.header');
    if (nav && header && header.nextSibling !== nav) {
      header.parentNode.insertBefore(nav, header.nextSibling);
    }
  })();
---
{%- set fnav = collections | getFinancePager(page.url) %}
{%- if fnav %}
<div class="month-nav no-print">
{%- if fnav.prev %}
  <a href="{{ fnav.prev.url }}">← {{ fnav.prev.data.title | replace(' 財務月報', '') }}</a>
{%- else %}
  <span></span>
{%- endif %}
{%- if fnav.next %}
  <a href="{{ fnav.next.url }}">{{ fnav.next.data.title | replace(' 財務月報', '') }} →</a>
{%- else %}
  <span></span>
{%- endif %}
</div>
{%- endif %}
{{ content | safe }}
{% if pdfUrl %}
<style>
/* 原始財報 PDF 橫幅樣式。刻意寫在 HTML 內（隨頁面出貨），不放 finance.css——
   因為 .css 會被 Cloudflare／瀏覽器邊緣快取，CSS 改了住戶端可能還拿到舊版，
   橫幅就會「有文字、沒樣式」。HTML 不被快取，inline style 永遠是新的。 */
.pdf-banner {
  display: flex; align-items: center; flex-wrap: wrap; gap: 10px 14px;
  margin: 0 0 26px; padding: 14px 18px;
  background: var(--paper2); border: 1px solid var(--border);
  border-left: 3px solid var(--blue); border-radius: 8px;
  font-size: 14px; color: var(--ink2);
}
.pdf-banner .pdf-banner-label { display: inline-flex; align-items: center; gap: 7px; }
.pdf-banner a {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 7px 16px; font-size: 14px; font-weight: 600;
  color: var(--paper); background: var(--blue);
  border-radius: 6px; text-decoration: none; letter-spacing: .02em;
  transition: opacity .18s;
}
.pdf-banner a:hover { opacity: .85; }
@media (max-width: 600px) { .pdf-banner { padding: 12px 14px; } }
@media print {
  .pdf-banner { border-left-color: #666; background: #f3f3f3; }
  .pdf-banner a { color: #000; background: transparent; border: 1px solid #666; padding: 2px 6px; }
}
</style>
<script>
/* 有原始財報 PDF 時，於內容區頂端自動插入連結橫幅（單頁分享給住戶時也看得到原始檔）。
   逐月維護由 frontmatter 的 pdfUrl 控制，模板只渲染一次，所有月報自動套用。 */
(function () {
  var url = "{{ pdfUrl }}";
  var main = document.querySelector(".main");
  if (!url || !main) return;
  var bar = document.createElement("div");
  bar.className = "pdf-banner";
  bar.innerHTML =
    '<span class="pdf-banner-label">📄 本頁為原始財務報表之數位彙整，原始檔（含完整收支明細）可於此查閱：</span>' +
    '<a href="' + url + '" target="_blank" rel="noopener">↓ 檢視／下載原始財報 PDF</a>';
  main.insertBefore(bar, main.firstChild);
})();
</script>
{% endif %}
