---
layout: base.njk
pageCss: notice.css
trilingual: true
extraScripts: |
  // 三語切換用共用 /lang.js（trilingual:true）。核心 .lang-btn/.lang-block/[data-lang-text]
  // 切換＋html lang 由 lang.js 處理；公告獨有的「類別標籤 #type-label 隨語言改字」插在掛鉤。
  window.onLangChange = function (lang) {
    const labelEl = document.getElementById('type-label');
    if (labelEl && labelEl.dataset[lang]) labelEl.textContent = labelEl.dataset[lang];
  };
---
<div class="header">
  <div class="header-inner">
    <h1>
      <span data-lang-text="zh">{{ titleZh }}</span>
      <span data-lang-text="en" style="display:none">{{ titleEn }}</span>
      <span data-lang-text="ja" style="display:none">{{ titleJa }}</span>
    </h1>
    <div class="header-meta">
      <span class="type-pill pill-{{ pillType }}" id="type-label"
            data-zh="{{ typeZh }}" data-en="{{ typeEn }}" data-ja="{{ typeJa }}">{{ typeZh }}</span>
      <span>{{ displayDate }}</span>
      <span>閱大安管理委員會</span>
    </div>
  </div>
</div>
<div class="lang-bar">
  <div class="lang-bar-inner">
    <button class="lang-btn active" data-lang="zh" onclick="setLang('zh')">中文</button>
    <button class="lang-btn" data-lang="en" onclick="setLang('en')">English</button>
    <button class="lang-btn" data-lang="ja" onclick="setLang('ja')">日本語</button>
  </div>
</div>
<div class="main">
{{ content | safe }}
</div>
