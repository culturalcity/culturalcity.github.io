# ──────────────────────────────────────────────
# 財務原始報表：僅作為製作 HTML 分析頁的素材，
# 不需要上傳至 GitHub Pages 網站空間。
# ──────────────────────────────────────────────
*.pdf
*.docx
*.xlsx
*.xls
*.csv

# macOS 系統檔
.DS_Store
**/.DS_Store

# Windows 縮圖快取
Thumbs.db

# Node.js 與 11ty
node_modules/
_site/

# Claude Code 內部資料
.claude/

# Playwright MCP 除錯產物（console/page dump，不上線）
.playwright-mcp/

# 環境變數（含 API 金鑰，禁止上傳）
.env
.env.local

# Claude 工作筆記
CLAUDE.md

# 原始素材（不上線、不公開）
raw/
RAW/

# 實驗用 demo / 草稿（不上線、不公開）
demo/

# clasp（Google Apps Script CLI）
# .clasp.json 內含 SCRIPT_ID，雖非 secret 但對 public repo 是 attempt vector
# 改用 .clasp.json.example 作為範本（commit 進 repo），新主委自行複製為 .clasp.json
.clasp.json
# ~/.clasprc.json 是 OAuth refresh token（絕對不能 commit）
# 該檔放在 user home 目錄、預設不會進 repo，但 future-proof 還是 ignore
.clasprc.json
